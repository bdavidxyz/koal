{
  "private": true,
  "type": "module",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "c8": "^11.0.0",
    "jsdom": "^25.0.0",
    "rollup": "^4.40.0",
    "run-pty": "^5.0.0",
    "vite": "^6.3.5",
    "vite-plugin-rails": "^0.5.0",
    "vite-plugin-ruby": "^5.1.1"
  },
  "scripts": {
    "test": "node --experimental-test-module-mocks --test app/frontend/jstest/**/*.test.js",
    "test:coverage": "c8 --reports-dir=coveragejs --reporter=text node --experimental-test-module-mocks --test app/frontend/jstest/**/*.test.js",
    "test:coverage:html": "c8 --reports-dir=coveragejs --reporter=html node --experimental-test-module-mocks --test app/frontend/jstest/**/*.test.js && echo '\nHTML coverage report generated at: coveragejs/index.html'"
  },
  "c8": {
    "include": [
      "app/frontend/up_compiler/**/*.js"
    ],
    "exclude": [
      "**/*.test.js",
      "**/*.spec.js",
      "app/frontend/jstest/**",
      "app/frontend/up_compiler/all.js"
    ],
    "all": true,
    "reporter": [
      "html",
      "text",
      "lcov"
    ],
    "reportsDir": "coveragejs"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "choices.js": "^11.1.0",
    "esbuild": ">=0.25.0",
    "tailwindcss": "^4.1.4",
    "unpoly": "3.14.1"
  },
  "engines": {
    "node": "22.x"
  }
}
