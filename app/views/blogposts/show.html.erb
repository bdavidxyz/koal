<div class="mx-auto max-w-3xl px-4 py-8 lg:py-12">

  <%= link_to blogposts_path, class: "group inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-900 transition-colors mb-8" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    See all posts
  <% end %>

  <article>
    <div class="mb-6">
      <% if @blogpost.blogtags.any? %>
        <div class="flex flex-wrap gap-2 mb-4">
          <% @blogpost.blogtags.each do |tag| %>
            <span class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-0.5 text-xs font-medium text-zinc-600"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>

      <h1 class="text-4xl font-bold leading-tight tracking-tight text-zinc-900 lg:text-5xl">
        <%= @blogpost.title %>
      </h1>

      <% if @blogpost.chapo.present? %>
        <p class="mt-4 text-xl leading-relaxed text-zinc-500">
          <%= @blogpost.chapo %>
        </p>
      <% end %>
    </div>

    <div class="flex items-center gap-3 py-4 border-y border-zinc-200">
      <img class="w-9 h-9 rounded-full bg-zinc-100" src="/img/avatardefault.svg" alt="Admin">
      <div class="flex flex-col">
        <span class="text-sm font-medium text-zinc-900">Admin</span>
        <time class="text-sm text-zinc-500" pubdate datetime="<%= @blogpost.published_at.iso8601 %>">
          <%= @blogpost.published_at.strftime("%-d %B %Y") %>
        </time>
      </div>
    </div>

    <div class="prose prose-zinc max-w-none mt-8">
      <%= Kramdown::Document.new(@blogpost.kontent).to_html.html_safe %>
    </div>
  </article>

  <hr class="border-zinc-200 my-10">

  <%= link_to blogposts_path, class: "group inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 hover:underline" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    See all posts
  <% end %>

</div>
