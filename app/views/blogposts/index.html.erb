<section class="bg-white dark:bg-gray-900">
  <div class="py-12 px-4 mx-auto max-w-screen-xl lg:py-20 lg:px-8">
    <div class="flex flex-col gap-12 lg:flex-row lg:gap-16">

      <!-- Left: intro panel -->
      <div class="lg:w-2/5 lg:sticky lg:top-20 lg:self-start">
        <p class="text-xs font-semibold tracking-widest uppercase text-gray-500 dark:text-gray-400 mb-4">Our Blogs</p>
        <h1 id="blogtitle" class="text-3xl lg:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-4">What We're Learning</h1>
        <p class="text-gray-500 dark:text-gray-400 mb-8">A collection of thoughts, experiments, and learnings from our team — covering UX, code, product, and everything in between.</p>
        <%= link_to blogposts_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" do %>
          View All Blogs
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>

      <!-- Right: blog post list -->
      <div class="lg:w-3/5 flex flex-col gap-3">
        <% if @blogposts.any? %>
          <% @blogposts.each do |blogpost| %>
            <%= link_to blogpost_path(blogpost.slug), class: "group flex items-center justify-between gap-4 p-5 bg-gray-100 dark:bg-gray-800 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" do %>
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 mb-1.5">
                  <% if blogpost.blogtags.any? %>
                    <span><%= blogpost.blogtags.first.name %></span>
                  <% else %>
                    <span>Article</span>
                  <% end %>
                  <span class="text-gray-300 dark:text-gray-600">&bull;</span>
                  <span><%= blogpost.published_at.strftime("%-d %B %Y") %></span>
                </div>
                <h2 class="text-base font-bold text-gray-900 dark:text-white leading-snug"><%= blogpost.title %></h2>
              </div>
              <div class="shrink-0 text-gray-400 dark:text-gray-500 group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </div>
            <% end %>
          <% end %>

          <% if @pagy.pages > 1 %>
            <div class="flex justify-center mt-4">
              <%== pagy_nav(@pagy) %>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center justify-center py-16 bg-gray-100 dark:bg-gray-800 rounded-xl">
            <div class="text-center">
              <p class="text-gray-500 dark:text-gray-400 font-medium">No articles yet</p>
              <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Check back soon for new content!</p>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</section>
