<div class="p-4 bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 rounded-md lg:p-10 h-full">
  <div class="sm:flex items-center justify-between mb-3">
    <h1 class="flex-1 text-2xl font-bold -tracking-wide mb-4">Admin Panel</h1>
  </div>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Background Jobs
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          Monitor and manage background jobs processing
        </div>
        <div class="mt-2 flex">
          <%= link_to "Open Background Jobs Dashboard", "/jobs", target: "_blank", class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0" %>
          <%= button_to "Trigger Hello World Job", myaccount_adminpanel_trigger_hello_world_job_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0 ml-2" %>
        </div>
      </div>
    </div>
  </section>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Error Monitoring
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          View and track application errors and exceptions
        </div>
        <div class="mt-2 flex">
          <%= link_to "Open Errors Dashboard", "/solid_errors", target: "_blank", class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0" %>
          <%= button_to "Trigger Division By Zero", myaccount_adminpanel_trigger_division_by_zero_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0 ml-2" %>
        </div>
      </div>
    </div>
  </section>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Slow page
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          Simulate a slow network query
        </div>
        <div class="mt-2 flex">
          <%= button_to "Simulate Slow Query", myaccount_adminpanel_simulate_slow_query_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0" %>
        </div>
      </div>
    </div>
  </section>
</div>