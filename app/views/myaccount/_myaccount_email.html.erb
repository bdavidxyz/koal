<%# locals: (user:) %>
<div class="p-4 bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 rounded-md lg:p-10 h-full">
  <div class="sm:flex items-center justify-between mb-5">
    <h1 class="flex-1 text-2xl font-bold -tracking-wide">Email</h1>
  </div>
  <section class="">
    <% if user.verified? %>
      <div class="text-sm">
        Your current email is <%= user.email %>
      </div>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-8">
        Change your email
      </h2>
      <%= form_with(url: identity_email_path, method: :patch) do |form| %>
        <% if user.errors.any? %>
          <div style="color: red">
            <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
            <ul>
              <% @user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div class="mt-4">
          <%= form.label :email, "New email", style: "display: block", class: "font-medium text-sm text-gray-700" %>
          <%= form.email_field :email, required: true, autofocus: true, class: "placeholder:text-sm placeholder:font-base placeholder:text-neutral-500 shadow-[0_1px_2px_#0000000d] border border-gray-300 text-neutral-700 rounded-md focus:border-2 focus:border-primary-400 focus:outline-none w-92 py-1 px-3" %>
        </div>
        <div class="mt-2">
          <%= form.label :password_challenge, style: "display: block", class: "font-medium text-sm text-gray-700" %>
          <%= form.password_field :password_challenge, required: true, autocomplete: "current-password", class: "placeholder:text-sm placeholder:font-base placeholder:text-neutral-500 shadow-[0_1px_2px_#0000000d] border border-gray-300 text-neutral-700 rounded-md focus:border-2 focus:border-primary-400 focus:outline-none w-92 py-1 px-3" %>
        </div>
        <div class="mt-8">
          <%= form.submit "Save changes", class: "cursor-pointer text-white bg-gray-900 hover:bg-gray-900/90 focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] font-medium rounded-md text-sm px-5 py-2" %>
        </div>
      <% end %>
    <% else %>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
        Verify your email
      </h2>
      <p class="mt-6 text-sm">We sent a verification email to <%= user.email %> </p>
      <p class="mt-2 text-sm"><strong>Check that email</strong> and follow those instructions to confirm it's your email address.</p>
      <div class="flex mt-4 items-center">
        <%= button_to "Re-send verification email", identity_email_verification_path, class: "cursor-pointer text-white bg-gray-900 hover:bg-gray-900/90 focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] font-medium rounded-md text-sm px-5 py-2" %>
        <%= link_to "Back to my account", myaccount_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-5 py-2 ms-4" %>
      </div>
    <% end %>
  </section>
</div>