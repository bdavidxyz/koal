<div class="p-4 bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 rounded-md lg:p-10 h-full">
  <div class="sm:flex items-center justify-between mb-8">
    <h1 class="flex-1 text-2xl font-bold -tracking-wide">My account</h1>
  </div>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Current Session
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          Currently logged in as <%= current_user.email %>
        </div>
        <div class="mt-2 flex items-center gap-2">
          <%= button_to "Log out", current_session, method: :delete, class: "cursor-pointer text-white bg-gray-900 hover:bg-gray-900/90 font-medium rounded-md text-xs px-3 py-1.5", form: {"up-submit" => "false"} %>
          <%= link_to Current.user.verified? ? "Go to email modification" : "⚠ Verify email", myaccount_email_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-50 font-medium rounded-md text-sm px-3 py-1" %>
        </div>
      </div>
      <div>
        <%= link_to "View all sessions", myaccount_sessions_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 md:ms-4 md:me-2 mt-2 mb-2 md:mt-0 md:mb-0" %>
      </div>
    </div>
  </section>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Password
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          Your password can be changed below
        </div>
        <div class="mt-2">
          <%= link_to "Edit password", myaccount_password_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0" %>
        </div>
      </div>
    </div>
  </section>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Connected devices
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          All the devices connnected to your account
        </div>
        <div class="mt-2">
          <%= link_to "View connected devices", myaccount_sessions_path, class: "cursor-pointer text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-md text-sm px-3 py-1 mt-2 mb-2 md:mt-0 md:mb-0" %>
        </div>
      </div>
    </div>
  </section>
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-800 pb-2 mt-1">
      Danger zone
    </h2>
    <div class="mb-8 flex gap-8  mt-2">
      <div class="flex-1">
        <div class="text-neutral-700">
          You can delete your account and all the associated data below
        </div>
        <div class="mt-2">
          <%= link_to "Go to account deletion page", "/myaccount/danger", class: "cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-50 font-medium rounded-md text-sm px-3 py-1" %>
        </div>
      </div>
    </div>
  </section>
</div>
