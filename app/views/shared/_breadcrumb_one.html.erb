<%# locals: (text:, link: nil) %>
<li role="presentation" aria-hidden="true" class="text-gray-400 dark:text-gray-600 select-none">/</li>
<li class="inline-flex items-center">
  <% if link.present? %>
    <a class="transition-colors hover:text-gray-900 dark:hover:text-white" href="<%= link %>"><%= text %></a>
  <% else %>
    <span class="font-medium text-gray-900 dark:text-white"><%= text %></span>
  <% end %>
</li>
