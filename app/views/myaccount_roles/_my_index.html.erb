<div class="table-scroll p-4 bg-white border border-gray-200 dark:bg-gray-900 dark:border-gray-800 rounded-md lg:p-8 h-full space-y-4">

  <!-- Header row -->
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">Roles</h1>
    <div class="flex items-center gap-2">
      <form class="search" up-target=".table-scroll" up-focus="#q" up-history="true" method="get">
        <input type="hidden" name="page" id="page" value="<%= params[:page] || 1 %>" autocomplete="off">
        <div class="relative">
          <svg class="absolute left-2.5 top-2.5 h-4 w-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
          <input type="search" name="q" id="q" placeholder="Filter roles..." value="<%= params[:q] %>"
                 class="h-9 w-44 rounded-md border border-gray-200 bg-white pl-8 pr-3 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-0 dark:bg-gray-900 dark:border-gray-700 dark:text-gray-100">
        </div>
      </form>
      <%= link_to "New role", myaccount_role_new_path, class: "inline-flex items-center justify-center h-9 rounded-md bg-gray-900 px-4 text-sm font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 transition-colors whitespace-nowrap dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-200" %>
    </div>
  </div>

  <!-- Table -->
  <div class="rounded-md border border-gray-200 overflow-x-auto">
    <table class="w-full caption-bottom text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th scope="col" class="px-6 py-3 text-start text-sm font-bold">Action</th>
          <th scope="col" class="px-6 py-3 text-start text-sm font-bold">Id</th>
          <th scope="col" class="px-6 py-3 text-start text-sm font-bold">Name</th>
          <%
            col = 'created_at'
            is_sorted_asc  = params[:sort] == col && params[:direction] == 'asc'
            is_sorted_desc = params[:sort] == col && params[:direction] == 'desc'
          %>
          <th scope="col" class="px-6 py-3 text-start text-sm font-bold">
            <div class="up_sort_dropdown relative inline-block">
              <button data-sort-toggle class="inline-flex items-center gap-1.5 cursor-pointer hover:text-gray-900 dark:hover:text-gray-100 transition-colors font-bold text-sm">
                Created at
                <% if is_sorted_asc %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
                <% elsif is_sorted_desc %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
                <% end %>
              </button>
              <div data-sort-menu class="hidden absolute top-full left-0 mt-1 z-50 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md shadow-md min-w-[130px] py-1">
                <a href="?<%= build_sort_direction_href(col, 'asc', request.query_parameters) %>"
                   class="flex items-center justify-between px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
                   up-target=".table-scroll" up-history="true">
                  <span class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
                    Asc
                  </span>
                  <% if is_sorted_asc %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  <% end %>
                </a>
                <a href="?<%= build_sort_direction_href(col, 'desc', request.query_parameters) %>"
                   class="flex items-center justify-between px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
                   up-target=".table-scroll" up-history="true">
                  <span class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    Desc
                  </span>
                  <% if is_sorted_desc %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  <% end %>
                </a>
                <a href="?<%= build_sort_reset_href(request.query_parameters) %>"
                   class="flex items-center gap-2 px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800"
                   up-target=".table-scroll" up-history="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                  Reset
                </a>
              </div>
            </div>
          </th>
          <th scope="col" class="px-6 py-3 text-start text-sm font-bold">
            <a href="?<%= build_href_to_sort('updated_at', request.query_parameters) %>" class="inline-flex items-center gap-1.5 cursor-pointer hover:text-gray-900 dark:hover:text-gray-100 transition-colors">
              Updated at
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/>
              </svg>
            </a>
          </th>
        </tr>
      </thead>
      <tbody>
        <% @roles.each do |role| %>
          <tr class="border-b border-gray-200 last:border-b-0 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/40 transition-colors">
            <td class="px-4 py-3 align-middle whitespace-nowrap">
              <%= link_to "Edit", myaccount_role_edit_path(role.id), class: "inline-flex items-center justify-center h-7 rounded-md bg-gray-900 px-3 text-xs font-medium text-white hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-1 transition-colors mr-1.5 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-200" %>
              <%= link_to "Show", myaccount_role_show_path(role.id), class: "inline-flex items-center justify-center h-7 rounded-md border border-gray-200 bg-white px-3 text-xs font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-200 focus:ring-offset-1 transition-colors dark:border-gray-700 dark:bg-transparent dark:text-gray-300 dark:hover:bg-gray-800" %>
            </td>
            <td class="px-4 py-3 align-middle font-mono text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap"><%= role.id %></td>
            <td class="px-4 py-3 align-middle text-gray-900 dark:text-gray-100 font-medium whitespace-nowrap"><%= truncate(role&.name, length: 20, omission: "...") %></td>
            <td class="px-4 py-3 align-middle whitespace-nowrap">
              <div class="text-gray-900 dark:text-gray-100"><%= role.created_at.strftime('%-d %b %Y') %></div>
              <div class="text-xs text-gray-400 dark:text-gray-500"><%= role.created_at.strftime('%H:%M:%S') %></div>
            </td>
            <td class="px-4 py-3 align-middle whitespace-nowrap">
              <div class="text-gray-900 dark:text-gray-100"><%= role.updated_at.strftime('%-d %b %Y') %></div>
              <div class="text-xs text-gray-400 dark:text-gray-500"><%= role.updated_at.strftime('%H:%M:%S') %></div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between px-1">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> rows
    </p>
    <ul class="flex items-center">
      <%== pagy_nav(@pagy) %>
    </ul>
  </div>

</div>
