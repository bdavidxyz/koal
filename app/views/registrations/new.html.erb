<section class="relative flex flex-col items-center justify-center min-h-screen bg-zinc-50">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50"></div>
  
  <div id="signupdiv" class="relative w-full max-w-md px-4 lg:-mt-64">
    <div class="pb-8 flex items-center justify-center mb-0 mt-6 sm:mt-0">
      <%= render 'shared/brand_logo' %>
    </div>
    <div class="bg-white rounded-xl border border-zinc-200 shadow-sm">
      <div class="flex flex-col space-y-6 p-8">
        <div class="flex flex-col space-y-2 text-center">
          <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">
            Create a new account
          </h1>
          <p class="text-sm text-zinc-500">
            Enter your details to get started
          </p>
        </div>
        
        <% if Current.user %>
          <div class="rounded-lg bg-zinc-50 p-4 text-sm text-zinc-600">
            <p>You are already connected as <%= Current.user.email %></p>
            <p class="mt-2">
              Do you wish to <%= button_to "log out?", Current.session, method: :delete, class: "font-medium text-zinc-900 hover:underline cursor-pointer" %>
            </p>
          </div>
        <% else %>
          <div class="text-sm text-zinc-500 text-center pb-2">
            Already subscribed ? You can <%= link_to "sign in here", sign_in_path, class: "font-medium text-zinc-900 hover:underline" %>
          </div>
        <% end %>
        
        <%= form_with(url: sign_up_path, class: "flex flex-col gap-6") do |form| %>
          <% if @user.errors.any? %>
            <div class="rounded-lg bg-red-50 p-3 text-sm text-red-600 border border-red-200">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-circle"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                <span><%= pluralize(@user.errors.count, "error") %> prohibited account creation:</span>
              </div>
              <ul class="list-disc mt-2 ml-6">
                <% @user.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <div class="hidden">
            <input type="checkbox" value="1" name="hp" id="hp" autocomplete="off" tabindex="-1">
            <label for="hp">Huemans should NOT clik this.</label>
          </div>
          
          <div class="flex flex-col gap-2">
            <%= form.label :email, "E-mail", class: "text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70" %>
            <%= form.email_field :email, value: @user.email, required: true, autofocus: true, autocomplete: "email", class: "flex h-10 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" %>
          </div>
          
          <div class="flex flex-col gap-2">
            <%= form.label :password, "Password", class: "text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70" %>
            <%= form.password_field :password, required: true, autocomplete: "new-password", class: "flex h-10 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" %>
            <span class="text-xs text-zinc-500">at least 12 characters long</span>
          </div>
          
          <div class="flex flex-col gap-2">
            <%= form.label :password_confirmation, "Confirm password", class: "text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70" %>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "flex h-10 w-full rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm placeholder:text-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" %>
          </div>
          
          <%= form.button "", type: "submit", class: "inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-zinc-900 text-zinc-50 hover:bg-zinc-900/90 h-10 px-4 py-2 w-full cursor-pointer" do %>
            <span>Create my account</span>
            <span class="js-may-load"></span>
          <% end %>
        <% end %>
      </div>
    </div>
    
    <p class="text-center text-sm text-zinc-500 mt-4">
      By continuing, you agree to our <a href="#" class="underline underline-offset-4">Terms of Service</a> and <a href="#" class="underline underline-offset-4">Privacy Policy</a>.
    </p>
  </div>
</section>
